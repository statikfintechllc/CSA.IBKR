{
  "jvm": {
    "heap": {
      "initialMB": 128,
      "maxMB": 512
    },
    "threads": {
      "eventLoopPool": 4,
      "workerPool": 8
    },
    "gc": {
      "intervalMs": 30000,
      "aggressiveOnLow": true
    },
    "classpath": [
      "system/IBKR.CSA/clientportal.gw/dist/ibgroup.web.core.iblink.router.clientportal.gw.jar",
      "system/IBKR.CSA/clientportal.gw/build/lib/runtime"
    ],
    "mainClass": "ibgroup.web.core.iblink.router.clientportal.gw.GatewayStart",
    "args": ["system/IBKR.CSA/clientportal.gw/root/conf.yaml"]
  },
  "network": {
    "ibkrApiBase": "https://api.ibkr.com/v1/api",
    "gatewayPort": 5000,
    "proxyViaServiceWorker": true,
    "requestTimeoutMs": 30000
  },
  "logging": {
    "level": "INFO",
    "toConsole": true
  }
}
